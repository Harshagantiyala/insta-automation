# ============================================================
# InstaFlow Backend - Environment Variables
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to version control.
# ============================================================

# ---------- Server ----------
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000

# ---------- MySQL ----------
MYSQL_URI=mysql://root:rootpassword@localhost:3306/instaflow

# ---------- Redis (BullMQ + rate-limit counters) ----------
REDIS_URL=redis://localhost:6379

# ---------- Auth (SaaS dashboard login) ----------
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ---------- Token Encryption ----------
# Used to AES-encrypt long-lived IG/FB access tokens before storing in MongoDB.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_char_hex_string

# ============================================================
# META (Facebook/Instagram) APP CREDENTIALS
# Get these from https://developers.facebook.com -> Your App -> Settings -> Basic
# ============================================================
META_APP_ID=__INSERT_META_APP_ID_HERE__
META_APP_SECRET=__INSERT_META_APP_SECRET_HERE__

# The redirect URI registered in Meta App > Facebook Login > Settings.
# Must exactly match (including protocol + path) what you enter in the Meta dashboard.
META_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/meta/callback

# Arbitrary string YOU choose. Meta sends this back during webhook verification (GET /webhooks/instagram).
# Must match the "Verify Token" field you set in Meta App > Webhooks > Instagram.
META_WEBHOOK_VERIFY_TOKEN=__CHOOSE_YOUR_OWN_SECRET_STRING__

# Graph API version - bump as Meta deprecates old versions.
META_GRAPH_API_VERSION=v20.0

# ---------- Stripe (Billing) ----------
# From https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=__INSERT_STRIPE_SECRET_KEY_HERE__
STRIPE_WEBHOOK_SECRET=__INSERT_STRIPE_WEBHOOK_SIGNING_SECRET_HERE__
STRIPE_PRICE_ID_STARTER=__INSERT_STRIPE_PRICE_ID_STARTER__
STRIPE_PRICE_ID_PRO=__INSERT_STRIPE_PRICE_ID_PRO__

# ---------- Rate Limiting / Safety ----------
DM_HOURLY_LIMIT_PER_ACCOUNT=200
DUPLICATE_MESSAGE_WINDOW_HOURS=24
